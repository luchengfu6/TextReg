# Copy this file to .env and fill in the keys you need. Loaded automatically
# by examples/run_textreg.py via python-dotenv.

# OpenAI (required when using OpenAI engines such as gpt-4o)
OPENAI_API_KEY=

# Optional: override OpenAI base URL (useful for proxies / Azure / local OpenAI-compatible servers)
# OPENAI_API_BASE=

# Optional: HuggingFace token (if you pull gated models for the solver)
# HUGGINGFACE_HUB_TOKEN=

# Optional: base URL for Ollama / vLLM / other OpenAI-compatible local servers
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_URL=http://localhost:8000/v1
